<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@../css/profilesTab.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.tiffixexamweblager.GUI.Controllers.ProfilesTabController">
   <children>
      <VBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="505.0" prefWidth="772.0" spacing="5.0">
         <children>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <HBox alignment="CENTER_LEFT" prefHeight="32.0" prefWidth="606.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Profiles">
                           <font>
                              <Font name="Roboto Regular" size="24.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <Button mnemonicParsing="false" onAction="#handleCreateProfile" prefHeight="32.0" prefWidth="138.0" styleClass="action-btn" text="Create Profile">
                     <cursor>
                        <Cursor fx:constant="DEFAULT" />
                     </cursor>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
            <TableView fx:id="tblProfiles" prefHeight="505.0" prefWidth="752.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colTitle" prefWidth="602.3333740234375" text="Title" />
                  <TableColumn fx:id="colManage" prefWidth="147.6666259765625" text="Manage" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <padding>
            <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <StackPane.margin>
            <Insets left="50.0" right="50.0" />
         </StackPane.margin>
      </VBox>
       <VBox fx:id="createProfileOverlay" alignment="CENTER" managed="false" visible="false">
           <fx:include fx:id="createProfile" source="../components/CreateProfileCard.fxml" />
       </VBox>
   </children>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dk.easv.tiffixexamweblager.GUI.Controllers.AssignEmployeeProfileController"
      styleClass="bg-default"
      spacing="0"
      prefWidth="420">

    <!-- Header -->
    <VBox spacing="4" styleClass="bg-subtle">
        <padding>
            <Insets top="16" right="20" bottom="16" left="20"/>
        </padding>
        <Label text="Assign Employees" styleClass="title-4"/>
        <Label text="Select an employee from the dropdown and click Assign."
               styleClass="text-muted, text-small"/>
    </VBox>

    <Separator/>

    <!-- Body -->
    <VBox spacing="12">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Dropdown + Assign -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <ComboBox fx:id="employeeDropdown"
                      promptText="Select employee..."
                      HBox.hgrow="ALWAYS"
                      maxWidth="Infinity"/>
            <Button fx:id="btnAssign"
                    text="Assign"
                    onAction="#handleAssign"
                    styleClass="accent"/>
        </HBox>

        <!-- Assigned list -->
        <Label text="Assigned Employees" styleClass="text-bold"/>

        <ListView fx:id="assignedList"
                  prefHeight="200"
                  maxWidth="Infinity"/>
    </VBox>

    <Separator/>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT">
        <padding>
            <Insets top="12" right="20" bottom="12" left="20"/>
        </padding>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnClose"
                text="Close"
                onAction="#handleClose"
                styleClass="button-outlined"/>
    </HBox>

</VBox>
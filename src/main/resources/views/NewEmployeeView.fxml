<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/24.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dk.easv.tiffixexamweblager.GUI.Controllers.NewEmployeeController"
           alignment="CENTER"
           stylesheets="@../css/style.css">

   <VBox alignment="CENTER"
         minWidth="320" prefWidth="320" maxWidth="320"
         minHeight="420" prefHeight="420" maxHeight="420"
         spacing="4.0"
         styleClass="card">

      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </padding>

      <HBox alignment="CENTER">
         <Label styleClass="h2" text="Create Employee" />
         <VBox.margin><Insets bottom="12.0" /></VBox.margin>
      </HBox>

      <VBox spacing="4.0">
         <padding><Insets top="4.0" /></padding>

         <TextField fx:id="txtFirstName"
                    maxWidth="Infinity"
                    promptText="First Name"
                    styleClass="text-field" />
         <Label fx:id="lblFirstNameError"
                prefHeight="14.0" maxWidth="Infinity"
                visible="false" managed="false"
                styleClass="error-label" />

         <TextField fx:id="txtLastName"
                    maxWidth="Infinity"
                    promptText="Last Name"
                    styleClass="text-field" />
         <Label fx:id="lblLastNameError"
                prefHeight="14.0" maxWidth="Infinity"
                visible="false" managed="false"
                styleClass="error-label" />

         <TextField fx:id="txtUserName"
                    maxWidth="Infinity"
                    promptText="Username"
                    styleClass="text-field" />
         <Label fx:id="lblUsernameError"
                prefHeight="14.0" maxWidth="Infinity"
                visible="false" managed="false"
                styleClass="error-label" />

         <TextField fx:id="txtPassword"
                    maxWidth="Infinity"
                    promptText="Password"
                    styleClass="text-field" />
         <Label fx:id="lblPasswordError"
                prefHeight="14.0" maxWidth="Infinity"
                visible="false" managed="false"
                styleClass="error-label" />
      </VBox>

      <HBox alignment="CENTER_RIGHT" spacing="8.0">
         <VBox.margin><Insets top="16.0" /></VBox.margin>
         <Button fx:id="btnCreate"
                 mnemonicParsing="false"
                 onAction="#onBtnCreate"
                 styleClass="button, accent"
                 text="Create" />
         <Button fx:id="btnCancel"
                 mnemonicParsing="false"
                 onAction="#onBtnCancel"
                 styleClass="button"
                 text="Cancel" />
      </HBox>

   </VBox>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox maxWidth="320.0" prefHeight="328.0" prefWidth="250.0" spacing="4.0" styleClass="card" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.tiffixexamweblager.GUI.Controllers.components.NewEmployeeController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <HBox alignment="CENTER">
      <Label styleClass="brand-title" text="Tiffix" />
   </HBox>
   <HBox alignment="CENTER">
      <Label fx:id="lblCreatingEmployee" styleClass="lbl-title" text="Creating a new employee" />
      <VBox.margin><Insets bottom="10.0" /></VBox.margin>
   </HBox>
   <VBox prefHeight="197.0" prefWidth="210.0" spacing="5.0">
      <children>
         <TextField fx:id="txtFirstName" promptText="First Name" />
         <Label fx:id="lblFirstNameError" minHeight="20.0" prefHeight="20.0" prefWidth="210.0" style="-fx-text-fill: -color-danger-fg; -fx-font-size: 11px;" />

         <TextField fx:id="txtLastName" promptText="Last Name" />
         <Label fx:id="lblLastNameError" prefHeight="17.0" prefWidth="213.0" style="-fx-text-fill: -color-danger-fg; -fx-font-size: 11px;" />
         <TextField fx:id="txtUserName" promptText="Username" />
         <Label fx:id="lblUsernameError" prefHeight="17.0" prefWidth="218.0" style="-fx-text-fill: -color-danger-fg; -fx-font-size: 11px;"/>
         <TextField fx:id="txtPassword" promptText="Password" />
         <Label fx:id="lblPasswordError" prefHeight="17.0" prefWidth="220.0" style="-fx-text-fill: -color-danger-fg; -fx-font-size: 11px;" />
      </children>
      <padding>
         <Insets top="5.0" />
      </padding>
   </VBox>
   <HBox alignment="CENTER_RIGHT" spacing="5.0">
      <VBox.margin><Insets top="10.0" /></VBox.margin>
      <Button fx:id="btnCreate" mnemonicParsing="false" onAction="#onBtnCreate" styleClass="accent" text="Create" />
      <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#onBtnCancel" text="Cancel" />
   </HBox>

</VBox>

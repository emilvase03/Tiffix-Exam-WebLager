<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox maxHeight="Infinity" maxWidth="260" prefWidth="260" styleClass="sidebar" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.tiffixexamweblager.GUI.Controllers.SideBarController">

    <HBox alignment="TOP_LEFT" spacing="10" styleClass="sidebar-topbar">

        <Button mnemonicParsing="false" onAction="#onBtnCloseSideBar" styleClass="close-btn">
            <graphic>
                <FontIcon iconLiteral="bi-x-square-fill" styleClass="close-icon" />
            </graphic>
        </Button>

        <HBox alignment="CENTER_LEFT" spacing="6">
            <FontIcon iconLiteral="bi-gear-fill" styleClass="sidebar-logo" />
            <Label styleClass="sidebar-app-name" text="TifFix" />
        </HBox>

    </HBox>

    <VBox spacing="4" styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="12" left="12" right="12" top="12" />
        </padding>

        <Button fx:id="btnEmployees" maxWidth="Infinity" mnemonicParsing="false" onAction="#onEmployees" styleClass="sidebar-btn, sidebar-btn-active" text=" Employees">
            <graphic>
                <HBox alignment="CENTER" spacing="6">
                    <FontIcon iconLiteral="bi-people" />
                </HBox>
            </graphic>
        </Button>

        <Button fx:id="btnProfiles" maxWidth="Infinity" mnemonicParsing="false" onAction="#onProfiles" styleClass="sidebar-btn" text=" Profiles" />
      <Button fx:id="btnCustomers" maxWidth="Infinity" mnemonicParsing="false" onAction="#onCustomers" styleClass="sidebar-btn" text="Customers" />

        <Region VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- ── Footer: version left, logout right ── -->
    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="sidebar-footer">

        <Label styleClass="sidebar-version" text="v1.0.0" />

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#onLogout" styleClass="sidebar-btn-logout">
            <graphic>
                <FontIcon iconLiteral="bi-box-arrow-right" />
            </graphic>
        </Button>

    </HBox>

</VBox>

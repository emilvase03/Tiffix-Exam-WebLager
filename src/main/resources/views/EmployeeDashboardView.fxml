<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.ModalPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<StackPane fx:id="root" prefHeight="574.0" prefWidth="687.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.tiffixexamweblager.GUI.Controllers.EmployeeDashboardController">
   <BorderPane fx:id="dashboardContent" prefHeight="448.0" prefWidth="550.0">
      <top>
         <VBox BorderPane.alignment="CENTER">
            <children>
               <HBox prefHeight="26.0" prefWidth="687.0" />
               <HBox fx:id="topToolBar" prefHeight="37.0" prefWidth="473.0" spacing="5.0">
                  <children>
                   <Button fx:id="btnLogout" onAction="#onLogout"
                           prefHeight="25.0" prefWidth="76.0" >
                       <graphic>
                           <FontIcon iconLiteral="bi-box-arrow-right"/>
                       </graphic>
    </Button>
                     <Button fx:id="StartScanningSession" mnemonicParsing="false" onAction="#onBtnStartScanningSession" prefHeight="25.0" prefWidth="179.0" text="Start scanning session" />
                     <Button mnemonicParsing="false" prefHeight="25.0" prefWidth="80.0" text="Fetch" />
                     <Region prefHeight="32.0" prefWidth="153.0" HBox.hgrow="ALWAYS" />
                     <Label prefHeight="17.0" prefWidth="112.0" text="Current Box" />
                     <Label fx:id="lblBoxID" prefHeight="17.0" prefWidth="46.0" text="ID" />
                     <Label prefHeight="17.0" prefWidth="115.0" text="Document Nr" />
                     <Label fx:id="lblDocumentNr" text="0" />
                  </children>
                  <padding>
                     <Insets left="5.0" right="5.0" top="5.0" />
                  </padding>
               </HBox>
            </children>
         </VBox>
      </top>
      <center>
         <SplitPane dividerPositions="0.5" BorderPane.alignment="CENTER">
            <items>
               <VBox fx:id="documentsPanel" prefHeight="511.0" prefWidth="360.0" spacing="5.0">
                  <children>
                     <HBox spacing="5.0">
                        <children>
                           <Label text="Total documents in the box:" />
                           <Label fx:id="lblTotalDocInBox" text="0" />
                        </children>
                     </HBox>
                     <ScrollPane fx:id="documentsScrollPane" fitToWidth="true" prefHeight="474.0" prefWidth="355.0">
                        <content>
                           <TilePane fx:id="documentsTilePane" hgap="10.0" prefColumns="4" prefHeight="437.0" prefWidth="353.0" vgap="10.0">
                              <padding>
                                 <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                              </padding>
                           </TilePane>
                        </content>
                     </ScrollPane>
                     <Button mnemonicParsing="false" onAction="#onBtnExport" text="Export" />
                  </children>
                  <padding>
                     <Insets bottom="5.0" left="5.0" />
                  </padding>
               </VBox>
               <VBox fx:id="filesPanel">
                  <children>
                     <Label alignment="TOP_LEFT" text="Files" />
                     <StackPane prefHeight="466.0" prefWidth="327.0">
                        <children>
                           <ScrollPane fx:id="filesScrolPane" prefHeight="466.0" prefWidth="314.0" styleClass="filesView">
                              <content>
                                 <TilePane hgap="14.0" prefColumns="4" prefHeight="458.0" prefWidth="315.0" vgap="14.0" />
                              </content>
                           </ScrollPane>
                           <BorderPane fx:id="topOverview" prefHeight="450.0" prefWidth="327.0" styleClass="preview" visible="false">
                              <top>
                                 <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                                    <children>
                                       <Label prefHeight="17.0" prefWidth="66.0" text="Preview" />
                                       <Region prefHeight="100.0" prefWidth="253.0" />
                                       <Button mnemonicParsing="false" onAction="#onBtnCloseOverview" text="X" />
                                    </children>
                                 </HBox>
                              </top>
                              <center>
                                 <ScrollPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                                    <content>
                                       <ImageView fx:id="previewImageView" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                    </content>
                                 </ScrollPane>
                              </center>
                              <bottom>
                                 <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                                    <children>
                                       <Button mnemonicParsing="false" onAction="#onBtnPreviousPage" text="Previous" />
                                       <Button mnemonicParsing="false" onAction="#onBtnRotate" text="Rotate" />
                                       <Button mnemonicParsing="false" onAction="#onBtnNext" text="Next" />
                                    </children>
                                 </HBox>
                              </bottom>
                           </BorderPane>
                           <VBox prefHeight="200.0" prefWidth="100.0" />
                        </children>
                     </StackPane>
                  </children>
                  <padding>
                     <Insets right="5.0" />
                  </padding>
               </VBox>
            </items>
         </SplitPane>
      </center>
   </BorderPane>

                                                            <ModalPane fx:id="modalPane" prefHeight="412.0" prefWidth="515.0" />
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="createBoxCard"
      maxHeight="-Infinity" maxWidth="-Infinity"
      minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="220.0" prefWidth="327.0"
      spacing="10.0"
      styleClass="overlay"
      stylesheets="@../css/profilesTab.css"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.tiffixexamweblager.GUI.Controllers.components.BoxCardController">
    <children>

        <Label fx:id="lblHeader" text="Create a new box.">
            <font>
                <Font name="Roboto Regular" size="12.0" />
            </font>
        </Label>

        <TextField fx:id="txtNumber"
                   prefHeight="26.0" prefWidth="307.0"
                   promptText="Box Number" />

        <TextField fx:id="txtTitle"
                   prefHeight="26.0" prefWidth="307.0"
                   promptText="Box Title" />

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button mnemonicParsing="false"
                        onAction="#handleSave"
                        prefWidth="73.0"
                        text="Save" />
                <Button mnemonicParsing="false"
                        onAction="#handleCancel"
                        prefHeight="26.0" prefWidth="73.0"
                        styleClass="dangerBtn"
                        text="Cancel" />
            </children>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </HBox>

    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="15.0" />
    </padding>
</VBox>
